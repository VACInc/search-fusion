{
  "name": "@openclaw/search-fusion",
  "version": "0.1.8",
  "description": "Federated OpenClaw web search fusion that fans out across configured providers, merges results, and preserves attribution.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/openclaw/search-fusion#readme",
  "bugs": {
    "url": "https://github.com/openclaw/search-fusion/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/search-fusion.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "search",
    "web-search",
    "clawhub"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.9",
      "minGatewayVersion": "2026.4.9"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    },
    "install": {
      "clawhubSpec": "clawhub:@openclaw/search-fusion",
      "npmSpec": "@openclaw/search-fusion",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.4.9"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --test --import tsx test/**/*.test.ts",
    "plugin:check": "plugin-inspector check --no-openclaw",
    "plugin:check:runtime": "plugin-inspector check --no-openclaw --runtime --mock-sdk --allow-execute",
    "plugin:ci": "plugin-inspector ci --no-openclaw --runtime --mock-sdk --allow-execute"
  },
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.4.9"
  },
  "devDependencies": {
    "@openclaw/plugin-inspector": "0.3.4",
    "@sinclair/typebox": "0.34.48",
    "@types/node": "^22.15.30",
    "openclaw": "2026.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
